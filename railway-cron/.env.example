# Base64-encoded Firebase service account JSON
# Generate from: Firebase Console > Project Settings > Service accounts > Generate new private key
# Then encode:
#   cat serviceAccountKey.json | base64 | pbcopy
FIREBASE_SERVICE_ACCOUNT=<your-base64-encoded-service-account-json>

# Firecrawl API key for scraping Eventbrite, Luma, Meetup
# Get one at https://firecrawl.dev
FIRECRAWL_API_KEY=<your-firecrawl-api-key>
