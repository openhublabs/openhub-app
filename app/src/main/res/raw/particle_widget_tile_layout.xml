<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tile_root"
    android:background="@drawable/widget_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/tile_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null"/>
    <FrameLayout
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_gravity="end|top"
            android:id="@+id/tile_logo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_particle_logo"
            android:tint="#ffffff"
            android:contentDescription="@string/app_name"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:ellipsize="end"
            android:layout_gravity="bottom"
            android:id="@+id/tile_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="4"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:fontWeight="700"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/widget_text_secondary"
            android:gravity="center"
            android:id="@+id/tile_empty_text"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/widget_no_news_available"/>
    </FrameLayout>
</FrameLayout>
