<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/contenedor_principal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo">

    <FrameLayout
        android:id="@+id/contenedor_fragmento"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/navegacion_inferior"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/sombra_navegacion"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/color_divisor"
        app:layout_constraintBottom_toTopOf="@id/navegacion_inferior"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navegacion_inferior"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/color_navegacion_fondo"
        app:itemIconTint="@color/selector_navegacion"
        app:itemTextColor="@color/selector_navegacion"
        app:itemActiveIndicatorStyle="@style/EstiloIndicadorNav"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_navegacion_inferior"
        app:elevation="@dimen/elevacion_navegacion"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
