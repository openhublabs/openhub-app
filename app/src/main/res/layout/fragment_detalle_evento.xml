<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="@color/transparente"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="@color/color_fondo"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:titleCollapseMode="fade">

            <ImageView
                android:id="@+id/imagen_detalle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7"
                tools:src="@tools:sample/backgrounds/scenic" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/degradado_scrim"
                app:layout_collapseMode="pin" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar_detalle"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_buscar" /> <!-- Placeholder icon, will be replaced programmatically -->

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margen_lateral_amplio">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/espaciado_medio">

                <TextView
                    android:id="@+id/etiqueta_categoria_detalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/fondo_etiqueta"
                    android:paddingHorizontal="@dimen/padding_etiqueta_horizontal"
                    android:paddingVertical="@dimen/padding_etiqueta_vertical"
                    android:textColor="@color/color_etiqueta_texto"
                    android:textSize="@dimen/texto_etiqueta"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    tools:text="HACKATHON" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/texto_tiempo_detalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_acento"
                    android:textSize="@dimen/texto_caption"
                    android:textStyle="bold"
                    tools:text="Hace 2 hr" />
            </LinearLayout>

            <TextView
                android:id="@+id/titulo_detalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_texto_principal"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:lineSpacingMultiplier="1.15"
                android:layout_marginBottom="@dimen/espaciado_grande"
                tools:text="Hackathon Lima 2026: Inteligencia Artificial Para El Cambio Social" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/espaciado_medio">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_explorar"
                    app:tint="@color/color_texto_secundario" />

                <TextView
                    android:id="@+id/texto_ubicacion_detalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/espaciado_medio"
                    android:textColor="@color/color_texto_principal"
                    android:textSize="@dimen/texto_subtitulo"
                    tools:text="Lima, Peru" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/espaciado_grande">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_historial"
                    app:tint="@color/color_texto_secundario" />

                <TextView
                    android:id="@+id/texto_fecha_detalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/espaciado_medio"
                    android:textColor="@color/color_texto_principal"
                    android:textSize="@dimen/texto_subtitulo"
                    tools:text="28 Jun 2026" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divisor"
                android:layout_marginBottom="@dimen/espaciado_grande" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Acerca del evento"
                android:textColor="@color/color_texto_principal"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/espaciado_medio" />

            <TextView
                android:id="@+id/descripcion_detalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_texto_secundario"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.4"
                tools:text="48 horas de innovacion donde equipos multidisciplinarios crearan soluciones con ia. Incluye talleres, mentorias y premios increibles." />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/color_fondo"
        android:padding="@dimen/margen_lateral_amplio"
        android:elevation="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_inscribirse"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/texto_inscribirse"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/color_texto_principal"
            android:textColor="@color/color_fondo" />
            
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
